<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- ── Header bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#25D366"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 WA Contact Saver"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── Status bar ── -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#128C7E"
            android:gravity="center"
            android:padding="10dp"
            android:text="Ready"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <!-- ── Accessibility alert button ── -->
        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_margin="12dp"
            android:backgroundTint="#FF5722"
            android:text="⚠️  Enable Accessibility Service (Required)"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <!-- ── Card: Naming Settings ── -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            card_view:cardCornerRadius="8dp"
            card_view:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Naming Settings"
                    android:textColor="#0D5C8C"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <!-- Prefix -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name Prefix"
                    android:textSize="12sp"
                    android:textColor="#555555" />
                <EditText
                    android:id="@+id/etPrefix"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g.  WA Contact  |  Lead  |  Customer "
                    android:inputType="text"
                    android:padding="8dp"
                    android:text="WA Contact " />

                <!-- Start number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start Numbering From"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="8dp" />
                <EditText
                    android:id="@+id/etStartNum"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:inputType="number"
                    android:padding="8dp"
                    android:text="1" />

                <!-- Padding -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number Padding"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="8dp" />
                <Spinner
                    android:id="@+id/spinnerPadding"
                    android:layout_width="match_parent"
                    android:layout_height="48dp" />

                <!-- Country code -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Country Code (digits only, e.g. 91 for India)"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="8dp" />
                <EditText
                    android:id="@+id/etCountryCode"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:inputType="number"
                    android:padding="8dp"
                    android:text="91" />

                <!-- Preview -->
                <TextView
                    android:id="@+id/tvPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#E8F5E9"
                    android:padding="10dp"
                    android:text="Preview →"
                    android:textColor="#1B5E20"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Action buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnStartScan"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#25D366"
                android:text="🚀 Start Scan"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnStopScan"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:backgroundTint="#B71C1C"
                android:enabled="false"
                android:text="⏹ Stop"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ── Live log ── -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            card_view:cardCornerRadius="8dp"
            card_view:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live Log"
                    android:textColor="#0D5C8C"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="6dp" />

                <ScrollView
                    android:id="@+id/scrollLog"
                    android:layout_width="match_parent"
                    android:layout_height="260dp">

                    <TextView
                        android:id="@+id/tvLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#1E1E1E"
                        android:fontFamily="monospace"
                        android:padding="10dp"
                        android:textColor="#00FF88"
                        android:textSize="11sp"
                        android:hint="Log will appear here…"
                        android:textColorHint="#555555" />
                </ScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── How-to note ── -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            card_view:cardCornerRadius="8dp"
            card_view:cardElevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="ℹ️  How to use\n\n1. Tap 'Enable Accessibility' and turn on WA Contact Saver.\n2. Set your naming prefix, start number and padding.\n3. Press 🚀 Start Scan — the app opens WhatsApp Business automatically and scrolls through ALL chats including archived.\n4. Unsaved numbers are detected and saved directly to your Contacts with your custom naming series.\n5. When done, open your phone's Contacts app to see the new entries."
                android:textColor="#333333"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
